  },
  "dependencies": {
    "@capacitor/android": "8.3.4",
    "@capacitor/core": "8.3.4",
    "@capacitor/ios": "8.3.4"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.4",
    "typescript": "6.0.3",
    "vite": "8.0.13"
  }
}
